@page "/Account/ResetPasswordConfirmation"
@page "/account/resetpasswordconfirmation"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Elevation="4" Class="pa-8 mt-16">
        <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Reset Password</MudText>

        <MudAlert Severity="Severity.Success" Class="mb-4">
            Your password has been successfully reset.
        </MudAlert>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   Href="@GetReturnUrl()">
            Return to Application
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrlHash")]
    public string ReturnUrlHash { get; set; }

    private string GetReturnUrl()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return ReturnUrl + (ReturnUrlHash ?? "");
        }
        return "/";
    }
}
