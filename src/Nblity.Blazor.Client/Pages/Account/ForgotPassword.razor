@page "/Account/ForgotPassword"
@page "/account/forgotpassword"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Elevation="4" Class="pa-8 mt-16">
        <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Forgot Password</MudText>
        <MudText Typo="Typo.body1" Class="mb-4" Align="Align.Center">
            Enter your email address to receive a password reset link.
        </MudText>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => ErrorMessage = null">
                @ErrorMessage
            </MudAlert>
        }

        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string"
                          @bind-Value="_email"
                          Label="Email address"
                          Required="true"
                          RequiredError="Email address is required"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleSubmit"
                       Disabled="@_isSubmitting"
                       Class="mb-4">
                @if (_isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Submit
            </MudButton>
        </MudForm>

        <MudText Align="Align.Center">
            <MudLink Href="@GetLoginUrl()">Back to Login</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrlHash")]
    public string ReturnUrlHash { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string Error { get; set; }

    private MudForm _form;
    private bool _isValid;
    private bool _isSubmitting;
    private string _email;
    private string ErrorMessage;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Error))
        {
            ErrorMessage = Error switch
            {
                "ForgotPasswordFailed" => "Failed to send password reset email. Please check your email address.",
                _ => "An error occurred. Please try again."
            };
        }
    }

    private async Task HandleSubmit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _isSubmitting = true;
        try
        {
            await JS.InvokeVoidAsync("nblityAuth.submitForm", "/auth/forgot-password", new Dictionary<string, string>
            {
                ["email"] = _email ?? "",
                ["returnUrl"] = ReturnUrl ?? "",
                ["returnUrlHash"] = ReturnUrlHash ?? ""
            });
        }
        catch
        {
            _isSubmitting = false;
            ErrorMessage = "An error occurred. Please try again.";
        }
    }

    private string GetLoginUrl()
    {
        var url = "/Account/Login";
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
            url += $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        return url;
    }
}
