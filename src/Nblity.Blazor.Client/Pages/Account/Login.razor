@page "/Account/Login"
@page "/account/login"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Elevation="4" Class="pa-8 mt-16">
        <MudText Typo="Typo.h4" GutterBottom="true" Align="Align.Center">Login</MudText>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => ErrorMessage = null">
                @ErrorMessage
            </MudAlert>
        }

        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string"
                          @bind-Value="_userNameOrEmailAddress"
                          Label="Username or email address"
                          Required="true"
                          RequiredError="Username or email address is required"
                          Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudTextField T="string"
                          @bind-Value="_password"
                          Label="Password"
                          InputType="@_passwordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          Required="true"
                          RequiredError="Password is required"
                          Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudCheckBox T="bool" @bind-Value="_rememberMe" Label="Remember me" Color="Color.Primary" />
                <MudLink Href="@GetForgotPasswordUrl()">Forgot password?</MudLink>
            </MudStack>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleLogin"
                       Disabled="@_isSubmitting"
                       Class="mb-4">
                @if (_isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Login
            </MudButton>
        </MudForm>

        <MudDivider Class="my-4" />
        <MudText Align="Align.Center">
            Don't have an account?
            <MudLink Href="@GetRegisterUrl()">Register</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrlHash")]
    public string ReturnUrlHash { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string Error { get; set; }

    private MudForm _form;
    private bool _isValid;
    private bool _isSubmitting;
    private string _userNameOrEmailAddress;
    private string _password;
    private bool _rememberMe;
    private string ErrorMessage;

    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Error))
        {
            ErrorMessage = Error switch
            {
                "InvalidUserNameOrPassword" => "Invalid username or password.",
                "UserLockedOut" => "User account is locked out. Please try again later.",
                "LoginIsNotAllowed" => "Login is not allowed.",
                "RequiresTwoFactor" => "Two-factor authentication is required.",
                "LocalLoginDisabled" => "Local login is disabled.",
                "InvalidInput" => "Please provide username and password.",
                _ => Uri.UnescapeDataString(Error)
            };
        }
    }

    private void TogglePasswordVisibility()
    {
        if (_passwordInputType == InputType.Password)
        {
            _passwordInputType = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            _passwordInputType = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private async Task HandleLogin()
    {
        await _form.Validate();
        if (!_isValid) return;

        _isSubmitting = true;
        try
        {
            await JS.InvokeVoidAsync("nblityAuth.submitForm", "/auth/login", new Dictionary<string, string>
            {
                ["userNameOrEmailAddress"] = _userNameOrEmailAddress ?? "",
                ["password"] = _password ?? "",
                ["rememberMe"] = _rememberMe.ToString(),
                ["returnUrl"] = ReturnUrl ?? "",
                ["returnUrlHash"] = ReturnUrlHash ?? ""
            });
        }
        catch
        {
            _isSubmitting = false;
            ErrorMessage = "An error occurred. Please try again.";
        }
    }

    private string GetRegisterUrl()
    {
        var url = "/Account/Register";
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
            url += $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        return url;
    }

    private string GetForgotPasswordUrl()
    {
        var url = "/Account/ForgotPassword";
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
            url += $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        return url;
    }
}
