@page "/Account/Logout"
@page "/account/logout"
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small">
    <MudPaper Elevation="4" Class="pa-8 mt-16">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Signing out...</MudText>
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrlHash")]
    public string ReturnUrlHash { get; set; }

    protected override void OnInitialized()
    {
        var logoutUrl = "/auth/logout";
        var queryParams = new List<string>();
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
            queryParams.Add($"returnUrl={Uri.EscapeDataString(ReturnUrl)}");
        if (!string.IsNullOrWhiteSpace(ReturnUrlHash))
            queryParams.Add($"returnUrlHash={Uri.EscapeDataString(ReturnUrlHash)}");

        if (queryParams.Count > 0)
            logoutUrl += "?" + string.Join("&", queryParams);

        Navigation.NavigateTo(logoutUrl, forceLoad: true);
    }
}
