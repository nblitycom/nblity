@using System.Globalization

@if (ViewModel.Languages.Count > 1 && ViewModel.HasLanguages)
{
	<MudMenu Icon="@Icons.Material.Filled.Language" Color="MudBlazor.Color.Inherit" Dense="true" AnchorOrigin="Origin.BottomCenter">
		@{
			var seen = new HashSet<string>();
			var languages = ViewModel.Languages.Select(language => seen.Add(language.TwoLetterISOLanguageName)
				? (language, language.TwoLetterISOLanguageName.ToUpper())
				: (language, language.CultureName.ToUpper())).ToList();
		}
		@foreach (var language in languages)
		{
			<MudMenuItem OnClick="@(() => ViewModel.LanguagePlatformManager.ChangeAsync(language.language))">
				@language.language.DisplayName / @language.Item2
			</MudMenuItem>
		}
	</MudMenu>
}
