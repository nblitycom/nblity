@{
	var items = new List<MudBlazor.BreadcrumbItem>();
	items.Add(new MudBlazor.BreadcrumbItem("Home", href: "/", icon: Icons.Material.Filled.Home));

	if (PageLayout.BreadcrumbItems.Any())
	{
		foreach (var breadcrumb in PageLayout.BreadcrumbItems)
		{
			items.Add(new MudBlazor.BreadcrumbItem(breadcrumb.Text, href: breadcrumb.Url));
		}
	}
	else if (!string.IsNullOrEmpty(PageLayout.Title))
	{
		items.Add(new MudBlazor.BreadcrumbItem(PageLayout.Title, href: null, disabled: true));
	}
}

<MudBreadcrumbs Items="@items" Class="pa-0 ma-0"></MudBreadcrumbs>
