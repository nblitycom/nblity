@using Volo.Abp.AspNetCore.Components.Notifications
@using Volo.Abp.BlazoriseUI
@inject IUiNotificationService UiNotificationService
@inject ISnackbar Snackbar
@implements IDisposable

@code {
    private BlazoriseUiNotificationService? _blazoriseService;

    protected override void OnInitialized()
    {
        if (UiNotificationService is BlazoriseUiNotificationService svc)
        {
            _blazoriseService = svc;
            _blazoriseService.NotificationReceived += OnNotificationReceived;
        }
    }

    private async void OnNotificationReceived(object? sender, UiNotificationEventArgs e)
    {
        await InvokeAsync(() =>
        {
            var severity = e.NotificationType switch
            {
                UiNotificationType.Success => MudBlazor.Severity.Success,
                UiNotificationType.Warning => MudBlazor.Severity.Warning,
                UiNotificationType.Error => MudBlazor.Severity.Error,
                _ => MudBlazor.Severity.Info
            };

            Snackbar.Add(e.Message, severity, config =>
            {
                if (!string.IsNullOrEmpty(e.Title))
                {
                    config.Action = e.Title;
                }
            });
        });
    }

    public void Dispose()
    {
        if (_blazoriseService != null)
        {
            _blazoriseService.NotificationReceived -= OnNotificationReceived;
        }
    }
}
