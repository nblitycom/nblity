@page "/account/manage-profile"
@using Microsoft.AspNetCore.Components.Forms
@using Volo.Abp.Account.Localization
@using Volo.Abp.AspNetCore.Components.Web
@using Volo.Abp.ObjectExtending
@using Volo.Abp.Data

@inject AbpBlazorMessageLocalizerHelper<AccountResource> LH
@inherits AbpAccountComponentBase

<MudGrid>
    <MudItem xs="12">
        <MudTabs @bind-ActivePanelIndex="@_selectedTabIndex" Position="MudBlazor.Position.Left" Rounded="true" ApplyEffectsToContainer="true">
            <MudTabPanel Text="@L["ProfileTab:Password"]">
                @if (ChangePasswordModel != null)
                {
                    <EditForm id="ChangePasswordForm" Model="@ChangePasswordModel" OnValidSubmit="ChangePasswordAsync">
                        <MudTextField T="string" InputType="InputType.Password" @bind-Value="@ChangePasswordModel.CurrentPassword" Label="@L["DisplayName:CurrentPassword"]" />
                        <MudTextField T="string" InputType="InputType.Password" @bind-Value="@ChangePasswordModel.NewPassword" Label="@L["DisplayName:NewPassword"]" />
                        <MudTextField T="string" InputType="InputType.Password" @bind-Value="@ChangePasswordModel.NewPasswordConfirm" Label="@L["DisplayName:NewPasswordConfirm"]" />
                        <MudButton ButtonType="MudBlazor.ButtonType.Submit" Color="MudBlazor.Color.Primary" Variant="Variant.Filled" OnClick="@ChangePasswordAsync">@L["Save"]</MudButton>
                    </EditForm>
                }
            </MudTabPanel>
            <MudTabPanel Text="@L["ProfileTab:PersonalInfo"]">
                @if (PersonalInfoModel != null)
                {
                    <EditForm id="UpdatePersonalInfoForm" Model="@PersonalInfoModel" OnValidSubmit="UpdatePersonalInfoAsync">
                        <MudTextField T="string" @bind-Value="@PersonalInfoModel.UserName" Label="@L["DisplayName:UserName"]" />
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string" @bind-Value="@PersonalInfoModel.Name" Label="@L["DisplayName:Name"]" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField T="string" @bind-Value="@PersonalInfoModel.Surname" Label="@L["DisplayName:Surname"]" />
                            </MudItem>
                        </MudGrid>
                        <MudTextField T="string" @bind-Value="@PersonalInfoModel.Email" Label="@L["DisplayName:Email"]" />
                        <MudTextField T="string" @bind-Value="@PersonalInfoModel.PhoneNumber" Label="@L["DisplayName:PhoneNumber"]" />

                        @* TODO: Implement MudBlazor-based extension property rendering when extension properties are configured.
                           Candidate approach: Use MudTextField/MudSelect/MudCheckBox based on property type from
                           ObjectExtensionManager.Instance.GetProperties<PersonalInfoModel>(). *@

                        <MudButton ButtonType="MudBlazor.ButtonType.Submit" Color="MudBlazor.Color.Primary" Variant="Variant.Filled" OnClick="@UpdatePersonalInfoAsync">@L["Save"]</MudButton>
                    </EditForm>
                }
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>