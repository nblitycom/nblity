@page "/identity/roles"
@attribute [Authorize(IdentityPermissions.Roles.Default)]
@using Volo.Abp.Identity
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.PermissionManagement.Blazor.Components
@using Volo.Abp.Identity.Localization
@using Volo.Abp.AspNetCore.Components.Web
@using Volo.Abp.AspNetCore.Components.Web.Theming
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using Volo.Abp.BlazoriseUI
@inject AbpBlazorMessageLocalizerHelper<IdentityResource> LH
@using Microsoft.Extensions.Localization
@using Volo.Abp.UI.Navigation.Localization.Resource
@inject IStringLocalizer<AbpUiNavigationResource> LUiNavigation

@inherits AbpCrudPageBase<IIdentityRoleAppService, IdentityRoleDto, Guid, GetIdentityRolesInput, IdentityRoleCreateDto, IdentityRoleUpdateDto>

<MudCard>
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">@L["Roles"]</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            @if (HasCreatePermission)
            {
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateModalAsync">
                    @L["NewRole"]
                </MudButton>
            }
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @* ************************* DATA TABLE ************************* *@
        <MudTable T="IdentityRoleDto"
                  Items="@Entities"
                  CurrentPage="@CurrentPage"
                  RowsPerPage="@PageSize"
                  Hover="true"
                  Breakpoint="MudBlazor.Breakpoint.Sm"
                  Dense="true">
            <HeaderContent>
                <MudTh>@L["Actions"]</MudTh>
                <MudTh>@L["RoleName"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["Actions"]">
                    <MudMenu Icon="@Icons.Material.Filled.MoreHoriz"
                             Size="MudBlazor.Size.Small"
                             Dense="true"
                             AnchorOrigin="Origin.BottomLeft">
                        @if (HasUpdatePermission)
                        {
                            <MudMenuItem OnClick="@(() => OpenEditModalAsync(context))">@L["Edit"]</MudMenuItem>
                        }
                        @if (HasManagePermissionsPermission)
                        {
                            <MudMenuItem OnClick="@(() => PermissionManagementModal.OpenAsync(PermissionProviderName, context.Name))">@L["Permissions"]</MudMenuItem>
                        }
                        @if (HasDeletePermission && !context.IsStatic)
                        {
                            <MudMenuItem OnClick="@(() => DeleteEntityAsync(context))">@L["Delete"]</MudMenuItem>
                        }
                    </MudMenu>
                </MudTd>
                <MudTd DataLabel="@L["RoleName"]">
                    <RoleNameComponent Data="@context" />
                </MudTd>
            </RowTemplate>
        </MudTable>
        <MudPagination Class="mt-4 d-flex justify-end"
                       Count="@((int)Math.Ceiling((double)(TotalCount ?? 0) / PageSize))"
                       Selected="@(CurrentPage + 1)"
                       SelectedChanged="@OnPageChangedAsync" />
    </MudCardContent>
</MudCard>

@* ************************* CREATE MODAL ************************* *@
@if (HasCreatePermission)
{
    <MudDialog @bind-Visible="CreateDialogVisible"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@L["NewRole"]</MudText>
        </TitleContent>
        <DialogContent>
            <EditForm Model="@NewEntity">
                <DataAnnotationsValidator />
                <MudTextField @bind-Value="@NewEntity.Name"
                              Label="@(L["DisplayName:RoleName"].Value + " *")"
                              AutoFocus="true"
                              Required="true"
                              Class="mb-4" />
                <MudCheckBox @bind-Value="@NewEntity.IsDefault"
                             Label="@L["DisplayName:IsDefault"]" />
                <MudCheckBox @bind-Value="@NewEntity.IsPublic"
                             Label="@L["DisplayName:IsPublic"]" />
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseCreateModalAsync"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary">
                @L["Cancel"]
            </MudButton>
            <MudButton OnClick="CreateEntityAsync"
                       Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary">
                @L["Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@* ************************* EDIT MODAL ************************* *@
@if (HasUpdatePermission)
{
    <MudDialog @bind-Visible="EditDialogVisible"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@L["Edit"]</MudText>
        </TitleContent>
        <DialogContent>
            <EditForm Model="@EditingEntity">
                <DataAnnotationsValidator />
                <input type="hidden" name="ConcurrencyStamp" @bind-value="EditingEntity.ConcurrencyStamp" />
                <MudTextField @bind-Value="@EditingEntity.Name"
                              Label="@(L["DisplayName:RoleName"].Value + " *")"
                              AutoFocus="true"
                              Required="true"
                              Class="mb-4" />
                <MudCheckBox @bind-Value="@EditingEntity.IsDefault"
                             Label="@L["DisplayName:IsDefault"]" />
                <MudCheckBox @bind-Value="@EditingEntity.IsPublic"
                             Label="@L["DisplayName:IsPublic"]" />
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseEditModalAsync"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary">
                @L["Cancel"]
            </MudButton>
            <MudButton OnClick="UpdateEntityAsync"
                       Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary">
                @L["Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@if (HasManagePermissionsPermission)
{
    <PermissionManagementModal @ref="PermissionManagementModal" />
}
