@page "/identity/users"
@attribute [Authorize(IdentityPermissions.Users.Default)]
@using Volo.Abp.Identity
@using Volo.Abp.Users
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.PermissionManagement.Blazor.Components
@using Volo.Abp.Identity.Localization
@using Volo.Abp.AspNetCore.Components.Web
@using Volo.Abp.AspNetCore.Components.Web.Theming
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using Volo.Abp.BlazoriseUI
@inject AbpBlazorMessageLocalizerHelper<IdentityResource> LH
@using Microsoft.Extensions.Localization
@using Volo.Abp.UI.Navigation.Localization.Resource
@inject IStringLocalizer<AbpUiNavigationResource> LUiNavigation

@inherits AbpCrudPageBase<IIdentityUserAppService, IdentityUserDto, Guid, GetIdentityUsersInput, IdentityUserCreateDto, IdentityUserUpdateDto>

<MudCard>
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">@L["Users"]</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudTextField T="string"
                          Value="@GetListInput.Filter"
                          ValueChanged="@OnSearchTextChanged"
                          Immediate="true"
                          Placeholder="@L["Search"]"
                          Variant="Variant.Outlined"
                          Margin="MudBlazor.Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="mr-4" />
            @if (HasCreatePermission)
            {
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateModalAsync">
                    @L["NewUser"]
                </MudButton>
            }
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @* ************************* DATA TABLE ************************* *@
        <MudTable T="IdentityUserDto"
                  Items="@Entities"
                  CurrentPage="@(CurrentPage - 1)"
                  RowsPerPage="@PageSize"
                  Hover="true"
                  Breakpoint="MudBlazor.Breakpoint.Sm"
                  Dense="true">
            <HeaderContent>
                <MudTh>@L["Actions"]</MudTh>
                <MudTh>@L["UserName"]</MudTh>
                <MudTh>@L["EmailAddress"]</MudTh>
                <MudTh>@L["PhoneNumber"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["Actions"]">
                    <MudMenu Icon="@Icons.Material.Filled.MoreHoriz"
                             Size="MudBlazor.Size.Small"
                             Dense="true"
                             AnchorOrigin="Origin.BottomLeft">
                        @if (HasUpdatePermission)
                        {
                            <MudMenuItem OnClick="@(() => OpenEditModalAsync(context))">@L["Edit"]</MudMenuItem>
                        }
                        @if (HasManagePermissionsPermission)
                        {
                            <MudMenuItem OnClick="@(async () => await PermissionManagementModal.OpenAsync(PermissionProviderName, context.Id.ToString(), context.UserName))">@L["Permissions"]</MudMenuItem>
                        }
                        @if (HasDeletePermission && CurrentUser.GetId() != context.Id)
                        {
                            <MudMenuItem OnClick="@(() => DeleteEntityAsync(context))">@L["Delete"]</MudMenuItem>
                        }
                    </MudMenu>
                </MudTd>
                <MudTd DataLabel="@L["UserName"]">@context.UserName</MudTd>
                <MudTd DataLabel="@L["EmailAddress"]">@context.Email</MudTd>
                <MudTd DataLabel="@L["PhoneNumber"]">@context.PhoneNumber</MudTd>
            </RowTemplate>
        </MudTable>
        <MudPagination Class="mt-4 d-flex justify-end"
                       Count="@((int)Math.Ceiling((double)(TotalCount ?? 0) / PageSize))"
                       Selected="@CurrentPage"
                       SelectedChanged="@OnPageChangedAsync" />
    </MudCardContent>
</MudCard>

@* ************************* CREATE MODAL ************************* *@
@if (HasCreatePermission)
{
    <MudDialog @bind-Visible="CreateDialogVisible"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@L["NewUser"]</MudText>
        </TitleContent>
        <DialogContent>
            <EditForm Model="@NewEntity">
                <DataAnnotationsValidator />
                <MudTabs>
                    <MudTabPanel Text="@L["UserInformations"]">
                        <MudTextField @bind-Value="@NewEntity.UserName"
                                      Label="@(L["DisplayName:UserName"].Value + " *")"
                                      AutoFocus="true"
                                      Required="true"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@NewEntity.Name"
                                      Label="@L["DisplayName:Name"]"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@NewEntity.Surname"
                                      Label="@L["DisplayName:Surname"]"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@NewEntity.Password"
                                      Label="@(L["DisplayName:Password"].Value + " *")"
                                      InputType="@(ShowPassword ? InputType.Text : InputType.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(ShowPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                      OnAdornmentClick="TogglePasswordVisibility"
                                      Required="true"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@NewEntity.Email"
                                      Label="@(L["DisplayName:Email"].Value + " *")"
                                      Required="true"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@NewEntity.PhoneNumber"
                                      Label="@L["DisplayName:PhoneNumber"]"
                                      Class="mb-4" />
                        <MudCheckBox @bind-Value="@NewEntity.IsActive"
                                     Label="@L["DisplayName:IsActive"]" />
                        <MudTooltip Text="@L["Description:LockoutEnabled"].Value" Placement="MudBlazor.Placement.End">
                            <MudCheckBox @bind-Value="@NewEntity.LockoutEnabled"
                                         Label="@L["DisplayName:LockoutEnabled"]" />
                        </MudTooltip>
                    </MudTabPanel>
                    <MudTabPanel Text="@L["Roles"]">
                        @if (NewUserRoles != null)
                        {
                            @foreach (var role in NewUserRoles)
                            {
                                <MudCheckBox @bind-Value="@role.IsAssigned"
                                             Label="@role.Name" />
                            }
                        }
                    </MudTabPanel>
                </MudTabs>
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseCreateModalAsync"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary">
                @L["Cancel"]
            </MudButton>
            <MudButton OnClick="CreateEntityAsync"
                       Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary">
                @L["Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@* ************************* EDIT MODAL ************************* *@
@if (HasUpdatePermission)
{
    <MudDialog @bind-Visible="EditDialogVisible"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@L["Edit"]</MudText>
        </TitleContent>
        <DialogContent>
            <EditForm Model="@EditingEntity">
                <DataAnnotationsValidator />
                <input type="hidden" name="ConcurrencyStamp" @bind-value="EditingEntity.ConcurrencyStamp" />
                <MudTabs>
                    <MudTabPanel Text="@L["UserInformations"]">
                        <MudTextField @bind-Value="@EditingEntity.UserName"
                                      Label="@(L["DisplayName:UserName"].Value + " *")"
                                      AutoFocus="true"
                                      Required="true"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@EditingEntity.Name"
                                      Label="@L["DisplayName:Name"]"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@EditingEntity.Surname"
                                      Label="@L["DisplayName:Surname"]"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@EditingEntity.Password"
                                      Label="@L["DisplayName:Password"]"
                                      InputType="@(ShowPassword ? InputType.Text : InputType.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(ShowPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                      OnAdornmentClick="TogglePasswordVisibility"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@EditingEntity.Email"
                                      Label="@(L["DisplayName:Email"].Value + " *")"
                                      Required="true"
                                      Class="mb-4" />
                        <MudTextField @bind-Value="@EditingEntity.PhoneNumber"
                                      Label="@L["DisplayName:PhoneNumber"]"
                                      Class="mb-4" />
                        @if (!IsEditCurrentUser)
                        {
                            <MudCheckBox @bind-Value="@EditingEntity.IsActive"
                                         Label="@L["DisplayName:IsActive"]" />
                        }
                        <MudTooltip Text="@L["Description:LockoutEnabled"].Value" Placement="MudBlazor.Placement.End">
                            <MudCheckBox @bind-Value="@EditingEntity.LockoutEnabled"
                                         Label="@L["DisplayName:LockoutEnabled"]" />
                        </MudTooltip>
                    </MudTabPanel>
                    @if (EditUserRoles != null && EditUserRoles.Any())
                    {
                        <MudTabPanel Text="@L["Roles"]">
                            @foreach (var role in EditUserRoles)
                            {
                                <MudCheckBox @bind-Value="@role.IsAssigned"
                                             Label="@role.Name" />
                            }
                        </MudTabPanel>
                    }
                </MudTabs>
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseEditModalAsync"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary">
                @L["Cancel"]
            </MudButton>
            <MudButton OnClick="UpdateEntityAsync"
                       Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary">
                @L["Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@if (HasManagePermissionsPermission)
{
    <PermissionManagementModal @ref="PermissionManagementModal" />
}
