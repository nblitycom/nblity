@page "/tenant-management/tenants"
@attribute [Authorize(TenantManagementPermissions.Tenants.Default)]
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.FeatureManagement.Blazor.Components
@using Microsoft.AspNetCore.Components.Forms
@using Volo.Abp.TenantManagement.Localization
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using Volo.Abp.AspNetCore.Components.Web
@using Volo.Abp.BlazoriseUI
@inject AbpBlazorMessageLocalizerHelper<AbpTenantManagementResource> LH
@using Microsoft.Extensions.Localization
@using Volo.Abp.UI.Navigation.Localization.Resource
@inject IStringLocalizer<AbpUiNavigationResource> LUiNavigation
@inherits AbpCrudPageBase<ITenantAppService, TenantDto, Guid, GetTenantsInput, TenantCreateDto, TenantUpdateDto>

<MudCard>
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">@L["Tenants"]</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            @if (HasCreatePermission)
            {
                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateModalAsync">
                    @L["NewTenant"]
                </MudButton>
            }
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent>
        @* ************************* DATA TABLE ************************* *@
        <MudTable T="TenantDto"
                  Items="@Entities"
                  CurrentPage="@CurrentPage"
                  RowsPerPage="@PageSize"
                  Hover="true"
                  Breakpoint="MudBlazor.Breakpoint.Sm"
                  Dense="true">
            <HeaderContent>
                <MudTh>@L["Actions"]</MudTh>
                <MudTh>@L["TenantName"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["Actions"]">
                    <MudMenu Icon="@Icons.Material.Filled.MoreHoriz"
                             Size="MudBlazor.Size.Small"
                             Dense="true"
                             AnchorOrigin="Origin.BottomLeft">
                        @if (HasUpdatePermission)
                        {
                            <MudMenuItem OnClick="@(() => OpenEditModalAsync(context))">@L["Edit"]</MudMenuItem>
                        }
                        @if (HasManageFeaturesPermission)
                        {
                            <MudMenuItem OnClick="@(() => FeatureManagementModal.OpenAsync(FeatureProviderName, context.Id.ToString(), context.Name))">@L["Features"]</MudMenuItem>
                        }
                        @if (HasDeletePermission)
                        {
                            <MudMenuItem OnClick="@(() => DeleteEntityAsync(context))">@L["Delete"]</MudMenuItem>
                        }
                    </MudMenu>
                </MudTd>
                <MudTd DataLabel="@L["TenantName"]">@context.Name</MudTd>
            </RowTemplate>
        </MudTable>
        <MudPagination Class="mt-4 d-flex justify-end"
                       Count="@((int)Math.Ceiling((double)TotalCount / PageSize))"
                       Selected="@(CurrentPage + 1)"
                       SelectedChanged="@OnPageChangedAsync" />
    </MudCardContent>
</MudCard>

@* ************************* CREATE MODAL ************************* *@
@if (HasCreatePermission)
{
    <MudDialog @bind-Visible="CreateDialogVisible"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@L["NewTenant"]</MudText>
        </TitleContent>
        <DialogContent>
            <EditForm Model="@NewEntity">
                <DataAnnotationsValidator />
                <MudTextField @bind-Value="@NewEntity.Name"
                              Label="@(L["TenantName"].Value + " *")"
                              AutoFocus="true"
                              Required="true"
                              Class="mb-4" />
                <MudTextField @bind-Value="@NewEntity.AdminEmailAddress"
                              Label="@(L["DisplayName:AdminEmailAddress"].Value + " *")"
                              InputType="InputType.Email"
                              Required="true"
                              Class="mb-4" />
                <MudTextField @bind-Value="@NewEntity.AdminPassword"
                              Label="@(L["DisplayName:AdminPassword"].Value + " *")"
                              InputType="@(ShowPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(ShowPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="TogglePasswordVisibility"
                              Required="true"
                              Class="mb-4" />
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseCreateModalAsync"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary">
                @L["Cancel"]
            </MudButton>
            <MudButton OnClick="CreateEntityAsync"
                       Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary">
                @L["Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@* ************************* EDIT MODAL ************************* *@
@if (HasUpdatePermission)
{
    <MudDialog @bind-Visible="EditDialogVisible"
               Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@L["Edit"]</MudText>
        </TitleContent>
        <DialogContent>
            <EditForm Model="@EditingEntity">
                <DataAnnotationsValidator />
                <MudTextField @bind-Value="@EditingEntity.Name"
                              Label="@(L["TenantName"].Value + " *")"
                              AutoFocus="true"
                              Required="true"
                              Class="mb-4" />
            </EditForm>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseEditModalAsync"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary">
                @L["Cancel"]
            </MudButton>
            <MudButton OnClick="UpdateEntityAsync"
                       Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary">
                @L["Save"]
            </MudButton>
        </DialogActions>
    </MudDialog>
}

@if (HasManageFeaturesPermission)
{
    <FeatureManagementModal @ref="FeatureManagementModal"/>
}