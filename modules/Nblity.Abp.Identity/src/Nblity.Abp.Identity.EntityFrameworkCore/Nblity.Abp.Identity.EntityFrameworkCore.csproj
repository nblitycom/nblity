    <CopyLocalLockFileAssemblies>True</CopyLocalLockFileAssemblies>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Volo.Abp.Users.EntityFrameworkCore" Version="10.1.0" />
    <ProjectReference Include="..\Nblity.Abp.Identity.Domain\Nblity.Abp.Identity.Domain.csproj" />
  </ItemGroup>
</Project>